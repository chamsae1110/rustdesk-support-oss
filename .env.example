# Broker portal configuration — copy to .env and fill in. NEVER commit .env.
#
# Master password for the operator (agent) login to the waiting room.
# Choose a strong value. This is a SECRET.
AGENT_PASS=change-me-to-a-strong-password

# HMAC secret for signing session cookies. Generate a random 64-hex string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is a SECRET.
SESSION_SECRET=generate-a-random-64-hex-string

# --- The following are non-secret and can also be set in docker-compose.yml ---
# PORT=3010
# BIND=0.0.0.0
# RUSTDESK_ID_SERVER=id.example.com
# CLIENT_DOWNLOAD_URL=https://support.example.com/dl/support-client.exe
# DEFAULT_ORG=demo
